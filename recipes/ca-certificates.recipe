name = ca-certificates
version = 2024.12.31
category = networking
description = Common CA certificates
homepage = https://wiki.mozilla.org/CA
license = MPL-2.0
epoch = 0
release = 1
build_style = custom

source =
    https://curl.se/ca/cacert-2024-12-31.pem    a3f328c21e39ddd1f2be1cea43ac0dec819eaa20a90425d7da901a11531b3aa5

pre_build_cmds =
    echo "all:" > Makefile
    echo "install:" >> Makefile

post_install_cmds =
    mkdir -p {{PREFIX}}/etc/ssl/certs
    cp ../../sources/ca-certificates-2024.12.31/cacert-2024-12-31.pem {{PREFIX}}/etc/ssl/certs/ca-certificates.crt
    ln -sf ca-certificates.crt {{PREFIX}}/etc/ssl/certs/ca-bundle.crt

depends =

makedepends =

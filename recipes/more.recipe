name = more
version = 2.10
category = devel
description = File perusal filter for crt viewing
homepage = https://www.gnu.org/software/util-linux/
license = GPL-2.0-or-later
epoch = 0
release = 1
build_style = gnu
extract_dir = util-linux-2.40

source =
    https://mirrors.edge.kernel.org/pub/linux/utils/util-linux/v2.40/util-linux-2.40.tar.xz    d57a626081f9ead02fa44c63a6af162ec19c58f53e993f206ab7c3a6641c2cd7

configure_args =
    --disable-all-programs
    --enable-more
    --disable-liblastlog2
    --without-python
    --without-systemd
    --without-udev

env_vars =
    CFLAGS=-D_PATH_VI=\"/data/data/tx.packages/files/usr/bin/vi\"

depends =
    ncurses

makedepends =

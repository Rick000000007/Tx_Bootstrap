name = lua
version = 5.4.7
category = languages
description = Lightweight programming language
homepage = https://www.lua.org/
license = MIT
epoch = 0
release = 1
build_style = custom

source =
    https://www.lua.org/ftp/lua-5.4.7.tar.gz    9fbf5e28ef86c69858f6d3d34eccc32e911c1a28b4120ff3e84aaa70cfbf1e30

pre_build_cmds =
    make -j4 -C src generic CC=clang AR="llvm-ar rcs" RANLIB=llvm-ranlib

post_install_cmds =
    make -C src install INSTALL_TOP="${DESTDIR}/data/data/tx.packages/files/usr"

depends =

makedepends =

name = sed
version = 4.9
category = core-utils
description = GNU Stream Editor
homepage = https://www.gnu.org/software/sed/
license = GPL-3.0-or-later
epoch = 0
release = 1
build_style = gnu

source =
    https://mirrors.kernel.org/gnu/sed/sed-4.9.tar.xz    6e226b732e1cd739464ad6862bd1a1aba42d7982922da7a53519631d24975181

env_vars =
    LIBS=-ldummy_tz
    ac_cv_func_strerror_r_char_p=no
    CFLAGS=-D__USE_FORTIFY_LEVEL=2

depends =

makedepends =

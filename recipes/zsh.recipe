name = zsh
version = 5.9
category = shells
description = Z Shell
homepage = https://www.zsh.org/
license = MIT-custom
epoch = 0
release = 1
build_style = gnu

source =
    https://ftp.osuosl.org/pub/blfs/conglomeration/zsh/zsh-5.9.tar.xz    9b8d1ecedd5b5e81fbf1918e876752a7dd948e05c1a0dba10ab863842d45acd5

depends =
    ncurses
    pcre2

env_vars =
    LDFLAGS=-lncursesw

makedepends =


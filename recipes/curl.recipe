name = curl
version = 8.11.1
category = networking
description = Command line tool and library for transferring data with URLs
homepage = https://curl.se/
license = curl
epoch = 0
release = 1
build_style = gnu

source =
    https://curl.se/download/curl-8.11.1.tar.xz    c7ca7db48b0909743eaef34250da02c19bc61d4f1dcedd6603f109409536ab56

configure_args =
    --with-openssl
    --without-ca-bundle
    --without-ca-path
    --without-ca-fallback

env_vars =
    LIBS=-ldl

depends =
    openssl
    zlib
    nghttp2
    libssh2

makedepends =

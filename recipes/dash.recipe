name = dash
version = 0.5.12
category = shells
description = Debian Almquist Shell
homepage = https://git.kernel.org/pub/scm/utils/dash/dash.git/
license = BSD-3-Clause
epoch = 0
release = 1
build_style = gnu

source =
    http://deb.debian.org/debian/pool/main/d/dash/dash_0.5.12.orig.tar.gz    6a474ac46e8b0b32916c4c60df694c82058d3297d8b385b74508030ca4a8f28a

env_vars =
    ac_cv_func_wait3=no

pre_build_cmds =
    sed -i 's/wait3(status, flags, NULL)/wait4(-1, status, flags, NULL)/g' src/jobs.c

depends =



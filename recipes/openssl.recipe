name = openssl
version = 3.4.0
category = networking
description = OpenSSL cryptography and SSL/TLS toolkit
homepage = https://www.openssl.org/
license = Apache-2.0
epoch = 0
release = 1
build_style = custom

source =
    https://www.openssl.org/source/openssl-3.4.0.tar.gz    e15dda82fe2fe8139dc2ac21a36d4ca01d5313c75f99f46c4e8a27709b7294bf

pre_build_cmds =
    ANDROID_NDK_ROOT="${ANDROID_NDK}" ./Configure android-arm64 -D__ANDROID_API__=29 --prefix=/data/data/tx.packages/files/usr no-shared no-tests
    make -j4
    make install_sw install_ssldirs DESTDIR="${DESTDIR}"

depends =

makedepends =

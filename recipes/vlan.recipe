name = vlan
version = 2.0.5
category = networking
description = User mode programs to enable VLANs on Ethernet devices
homepage = https://www.candelatech.com/~greear/vlan.html
license = GPL-2.0-only
epoch = 0
release = 1
build_style = custom

source =
    http://deb.debian.org/debian/pool/main/v/vlan/vlan_2.0.5.tar.xz    ccf261839b79247be8dae93074e1c5fcbce3807787a0ff7aed4e1f7a9095c465

pre_build_cmds =
    clang --target=aarch64-linux-android29 --sysroot=/home/runner/work/_temp/android-ndk/toolchains/llvm/prebuilt/linux-x86_64/sysroot vconfig.c -o vconfig

pre_install_cmds =
    mkdir -p "${DESTDIR}/data/data/tx.packages/files/usr/bin"
    mkdir -p "${DESTDIR}/data/data/tx.packages/files/usr/share/man/man8"
    cp vconfig "${DESTDIR}/data/data/tx.packages/files/usr/bin/"
    cp vconfig.8 "${DESTDIR}/data/data/tx.packages/files/usr/share/man/man8/"

depends =

makedepends =

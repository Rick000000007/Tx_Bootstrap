name = vim
version = 9.1.1106
category = editors
description = Vi IMproved - text editor
homepage = https://www.vim.org/
license = Vim
epoch = 0
release = 1
build_style = gnu
build_dir = .

source =
    https://github.com/vim/vim/archive/refs/tags/v9.1.1106.tar.gz    721e6d0d0fd4c95fa13808cf27ba976a6cf0fa225e77993d66dcecc20625f463

env_vars =
    vim_cv_toupper_broken=no
    vim_cv_terminfo=yes
    vim_cv_tty_group=world
    vim_cv_getcwd_broken=no
    vim_cv_stat_ignores_slash=no
    vim_cv_memmove_handles_overlap=yes

depends =
    ncurses

makedepends =

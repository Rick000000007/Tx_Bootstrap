name = wpa_supplicant
version = 2.11
category = networking
description = WPA/WPA2/IEEE 802.1X Supplicant
homepage = https://w1.fi/wpa_supplicant/
license = BSD-3-Clause
epoch = 0
release = 1
build_style = custom

source =
    https://w1.fi/releases/wpa_supplicant-2.11.tar.gz    912ea06f74e30a8e36fbb68064d6cdff218d8d591db0fc5d75dee6c81ac7fc0a

pre_build_cmds =
    cp wpa_supplicant/defconfig wpa_supplicant/.config
    sed -i 's/CONFIG_CTRL_IFACE_DBUS/#CONFIG_CTRL_IFACE_DBUS/g' wpa_supplicant/.config
    make -C wpa_supplicant -j4 CC=clang AR=llvm-ar RANLIB=llvm-ranlib
    make -C wpa_supplicant install DESTDIR="${DESTDIR}/wpa_supplicant"

depends =
    openssl
    libnl
    readline

makedepends =

name = git
version = 2.48.1
category = vcs
description = Distributed version control system
homepage = https://git-scm.com/
license = GPL-2.0-only
epoch = 0
release = 1
build_style = gnu
build_dir = .

source =
    https://www.kernel.org/pub/software/scm/git/git-2.48.1.tar.xz    1c5d545f5dc1eb51e95d2c50d98fdf88b1a36ba1fa30e9ae5d5385c6024f82ad

env_vars =
    ac_cv_fread_reads_directories=yes
    ac_cv_header_libintl_h=no
    ac_cv_iconv_omits_bom=no
    ac_cv_snprintf_returns_bogus=no

configure_args =
    --with-curl
    --with-expat
    --with-shell=/data/data/tx.packages/files/usr/bin/sh
    --without-tcltk

make_args =
    NO_NSEC=1
    NO_GETTEXT=1
    NO_INSTALL_HARDLINKS=1
    CSPRNG_METHOD=openssl
    PERL_PATH=/data/data/tx.packages/files/usr/bin/perl
    USE_LIBPCRE2=1

depends =
    openssl
    curl
    zlib
    expat
    pcre2

makedepends =

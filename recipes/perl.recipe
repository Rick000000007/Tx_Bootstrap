name = perl
version = 5.40.1
category = languages
description = Practical Extraction and Report Language
homepage = https://www.perl.org/
license = Artistic-1.0-Perl OR GPL-1.0-or-later
epoch = 0
release = 1
build_style = custom

source =
    https://www.cpan.org/src/5.0/perl-5.40.1.tar.xz    dfa20c2eef2b4af133525610bbb65dd13777ecf998c9c5b1ccf0d308e732ee3f
    https://github.com/arsv/perl-cross/releases/download/1.6.1/perl-cross-1.6.1.tar.gz    b5f4b4457bbd7be37adac8ee423beedbcdba8963a85f79770f5e701dabc5550f

pre_build_cmds =
    cp -rf ../perl-cross-1.6.1/* .
    ./configure --prefix=/data/data/tx.packages/files/usr --host=aarch64-linux-android
    make -j4
    make install DESTDIR="${DESTDIR}/perl"

depends =

makedepends =

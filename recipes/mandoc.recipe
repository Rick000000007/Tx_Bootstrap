name = mandoc
version = 1.14.6
category = doc
description = UNIX manpage compiler toolset
homepage = https://mandoc.bsd.lv/
license = ISC
epoch = 0
release = 1
build_style = custom

source =
    https://mandoc.bsd.lv/snapshots/mandoc-1.14.6.tar.gz    8bf0d570f01e70a6e124884088870cbed7537f36328d512909eb10cd53179d9c

pre_build_cmds =
    echo "PREFIX=/data/data/tx.packages/files/usr" > configure.local
    echo "CC=clang" >> configure.local
    echo "CFLAGS=\"${CFLAGS} -DNULL=0 -DBIONIC_IOCTL_NO_SIGNEDNESS_OVERLOAD\"" >> configure.local
    echo "LDFLAGS=\"${LDFLAGS}\"" >> configure.local
    echo "HAVE_STRLCAT=1" >> configure.local
    echo "HAVE_STRLCPY=1" >> configure.local
    echo "HAVE_SYS_ENDIAN=1" >> configure.local
    echo "HAVE_ENDIAN=1" >> configure.local
    echo "HAVE_NTOHL=1" >> configure.local
    echo "HAVE_NANOSLEEP=1" >> configure.local
    echo "HAVE_O_DIRECTORY=1" >> configure.local
    echo "HAVE_ISBLANK=1" >> configure.local
    ./configure

post_install_cmds =
    make install DESTDIR="$DESTDIR/mandoc"

depends =

makedepends =

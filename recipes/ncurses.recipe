name = ncurses
version = 6.5
category = libraries
description = Library for text-based user interfaces
homepage = https://invisible-island.net/ncurses/
license = MIT
epoch = 0
release = 1
build_style = gnu

source =
    https://invisible-island.net/archives/ncurses/ncurses-6.5.tar.gz    136d91bc269a9a5785e5f9e980bc76ab57428f604ce3e5a5a90cebc767971cc6

configure_args =
    --enable-widec
    --disable-stripping
    --without-debug
    --without-ada
    --without-tests
    --without-cxx-binding
    --program-prefix=

post_install_cmds =
    LIBDIR="${DESTDIR}/data/data/tx.packages/files/usr/lib" && mkdir -p "${LIBDIR}" && for lib in ncurses form panel menu; do ln -sf lib${lib}w.a "${LIBDIR}/lib${lib}.a"; done; true
    INCDIR="${DESTDIR}/data/data/tx.packages/files/usr/include" && mkdir -p "${INCDIR}" && ln -sf ncursesw "${INCDIR}/ncurses" && for h in ncurses.h curses.h term.h; do test -f "${INCDIR}/ncursesw/${h}" && ln -sf "ncursesw/${h}" "${INCDIR}/${h}"; done; true
    PKGDIR="${DESTDIR}/data/data/tx.packages/files/usr/lib/pkgconfig" && mkdir -p "${PKGDIR}" && test -f "${PKGDIR}/ncursesw.pc" && ln -sf ncursesw.pc "${PKGDIR}/ncurses.pc"; true

make_args =
    INSTALL="install -c"

depends =

makedepends =
